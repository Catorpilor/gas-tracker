# Gas Tracker API Configuration

# Server
PORT=3000

# Alchemy API Key (required)
# Get one at https://dashboard.alchemy.com/
ALCHEMY_API_KEY=your-alchemy-api-key

# Optional: Override individual chain RPC URLs
# If not set, URLs are constructed from ALCHEMY_API_KEY
# ALCHEMY_ETH_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
# ALCHEMY_BASE_URL=https://base-mainnet.g.alchemy.com/v2/your-key
# ALCHEMY_ARB_URL=https://arb-mainnet.g.alchemy.com/v2/your-key
# ALCHEMY_OPT_URL=https://opt-mainnet.g.alchemy.com/v2/your-key
# ALCHEMY_POLY_URL=https://polygon-mainnet.g.alchemy.com/v2/your-key

# Domain for Caddy (used in docker-compose)
DOMAIN=gas-tracker.demos.zeh.app

# x402 Payment Configuration
# Enable/disable x402 payments (default: true)
X402_ENABLED=true

# Network for payments (default: eip155:8453 = Base mainnet)
# Use eip155:84532 for Base Sepolia testnet
X402_NETWORK=eip155:8453

# Price per request (default: $0.05)
X402_PRICE=$0.05

# Wallet address to receive payments
X402_PAY_TO=0x7a767604FCd33fDc6eCA1775CBe4e66fDb5c0e79

# Facilitator URL (default: https://facilitator.payai.network)
# X402_FACILITATOR_URL=https://facilitator.payai.network
