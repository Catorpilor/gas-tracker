# Gas Tracker API
# Update the domain as needed

{$DOMAIN:gas-tracker.demos.zeh.app} {
    reverse_proxy gas-tracker:3000
    
    # Enable compression
    encode gzip
    
    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
    
    # Logging
    log {
        output stdout
        format json
    }
}

# Health check endpoint (optional, for external monitoring)
:80 {
    respond /health "OK" 200
}
